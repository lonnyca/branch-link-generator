      "RMID": "<%=delivery.deliveryCode%>",
      "RRID": "<%=preTrip.shaEmail%>",
      "mi_u": null,
      "mi_ecmp": null
    },
    "emailAddress": {
      "RR_NUMBER": "<%=emailAddress.sha1RRNum%>",
      "RSD": "<%=emailAddress.recipient.segment_Assigned%>",
